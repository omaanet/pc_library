# Required for Neon PostgreSQL access.
DATABASE_URL=

# Public application origin, for example http://localhost:3005.
NEXT_PUBLIC_APP_URL=

# Stable server-only secret for HMAC hashing anonymous promo visitor IPs.
# Generate at least 32 random bytes (for example, 64 hexadecimal characters).
# Use a different value in each environment and do not rotate it casually.
STATS_HASH_SECRET=

# SMTP configuration.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
